# ---------------------------------------------------------------------------
# vocal-helper — local settings
#
# Copy this file to ``settings.yaml`` (which is git-ignored) and fill in
# real values. The vocal-helper library reads it on import via
# ``vocal_helper._settings.resolve_hf_token`` so the CLI, the example
# scripts and any library caller behave identically.
#
# Resolution order for ``hf_token`` (highest priority first) :
#
#   1. Explicit ``--hf-token`` CLI flag or ``hf_token=`` kwarg.
#   2. ``HF_TOKEN`` environment variable.
#   3. ``secrets.hf_token`` below.
#
# The parser is hand-rolled (no PyYAML dependency) and only understands
# this flat two-level schema — keep new keys at the same indentation.
# ---------------------------------------------------------------------------

secrets:
  # HuggingFace access token used to download the gated pyannote models
  # (``pyannote/embedding`` for the online diarizer, plus
  # ``pyannote/speaker-diarization-3.1`` for the offline path). Create
  # one at https://huggingface.co/settings/tokens and accept the model
  # licences on the relevant model pages with the same account.
  hf_token: hf_XXXX
